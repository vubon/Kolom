<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox disabled: InputMethodKit requires direct system integration
	     that is incompatible with the app sandbox in some macOS versions.
	     This is standard practice for IMK-based input methods. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
